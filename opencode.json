{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    "skills/_shared.md",
    "skills/opencode-mcp.md"
  ],
  "model": "opencode/big-pickle",
  "permission": {
    "bash": "deny",
    "edit": "deny",
    "write": "deny",
    "webfetch": "deny",
    "lureguard_*": "allow"
  },
  "experimental": {
    "mcp_timeout": 180000
  },
  "mcp": {
    "lureguard": {
      "type": "local",
      "enabled": true,
      "command": [".venv/bin/python", "-m", "lureguard_mcp"],
      "timeout": 180000,
      "environment": {
        "POSTGRES_HOST": "localhost",
        "POSTGRES_PORT": "5433"
      }
    }
  }
}
