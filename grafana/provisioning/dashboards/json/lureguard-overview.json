            "location": { "latitude": "latitude", "longitude": "longitude", "mode": "coords" },
            "name": "Classified sources",
            "tooltip": true,
            "type": "markers"
          }
        ],
        "tooltip": { "mode": "details" },
        "view": { "allLayers": true, "id": "zero", "lat": 20, "lon": 0, "zoom": 1 }
