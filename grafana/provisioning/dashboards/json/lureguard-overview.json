      "pluginVersion": "11.4.0",
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT host(e.src_ip) AS src_ip, max(g.country_code) AS country_code, max(g.country_name) AS country_name, max(g.lat) AS latitude, max(g.lon) AS longitude, max(COALESCE((SELECT d.decision FROM sessions s JOIN decisions d ON d.session_id = s.id WHERE s.src_ip = e.src_ip ORDER BY abs(extract(epoch FROM (d.ts - e.ts))) LIMIT 1), CASE WHEN e.event_type IN ('auth_failed', 'cowrie_session', 'rootkit_detected', 'fim_change') THEN 'alert' WHEN e.event_type = 'auth_success' THEN 'allow' ELSE 'unclassified' END)) AS decision, count(*) AS events FROM events e INNER JOIN ip_geolocation g ON g.ip = e.src_ip WHERE $__timeFilter(e.ts) AND e.src_ip IS NOT NULL AND g.lat IS NOT NULL AND g.lon IS NOT NULL GROUP BY e.src_ip ORDER BY events DESC LIMIT 50",
