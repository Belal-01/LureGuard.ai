      "id": 4,
      "options": { "showHeader": true },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT channel, event_type, count(*) AS cnt FROM events WHERE $__timeFilter(ts) GROUP BY channel, event_type ORDER BY cnt DESC LIMIT 15",
