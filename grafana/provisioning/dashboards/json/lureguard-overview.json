{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "postgres", "uid": "lureguard-pg" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2, "showPoints": "never" } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "lureguard-pg" },
          "format": "time_series",
          "rawSql": "SELECT $__timeGroupAlias(ts, $__interval), channel AS metric, count(*) AS value FROM events WHERE $__timeFilter(ts) GROUP BY 1, channel ORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "Events by channel",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "postgres", "uid": "lureguard-pg" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "bars", "fillOpacity": 80 } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "lureguard-pg" },
          "format": "time_series",
          "rawSql": "SELECT $__timeGroupAlias(ts, $__interval), avg(wazuh_rule_level) AS value FROM events WHERE $__timeFilter(ts) AND wazuh_rule_level IS NOT NULL GROUP BY 1 ORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "Average alert level",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "postgres", "uid": "lureguard-pg" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "options": { "showHeader": true },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "lureguard-pg" },
          "format": "table",
          "rawSql": "SELECT host(src_ip) AS src_ip, count(*) AS events, max(wazuh_rule_level) AS max_level FROM events WHERE $__timeFilter(ts) AND src_ip IS NOT NULL GROUP BY src_ip ORDER BY events DESC LIMIT 10",
          "refId": "A"
        }
      ],
      "title": "Top source IPs",
      "type": "table"
    },
    {
      "datasource": { "type": "postgres", "uid": "lureguard-pg" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "options": { "showHeader": true },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "lureguard-pg" },
          "format": "table",
          "rawSql": "SELECT channel, event_type, count(*) AS cnt FROM events WHERE $__timeFilter(ts) GROUP BY channel, event_type ORDER BY cnt DESC LIMIT 15",
          "refId": "A"
        }
      ],
      "title": "Event types",
      "type": "table"
    },
    {
      "datasource": { "type": "postgres", "uid": "lureguard-pg" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "decision" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "allow": { "color": "green", "index": 0, "text": "allow" },
                      "alert": { "color": "red", "index": 1, "text": "alert" },
                      "redirect": { "color": "orange", "index": 2, "text": "redirect" },
                      "unclassified": { "color": "blue", "index": 3, "text": "unclassified" }
                    },
                    "type": "value"
                  }
                ]
              }
            ]
          }
        ]
      },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 16 },
      "id": 5,
      "options": {
        "basemap": { "name": "Layer 0", "type": "carto",   
        "config": {
          "theme": "dark",
          "showLabels": false
     } },
        "controls": {
          "mouseWheelZoom": true,
          "showAttribution": true,
          "showDebug": false,
          "showMeasure": false,
          "showScale": false,
          "showZoom": true
        },
        "layers": [
          {
            "config": {
              "showLegend": true,
              "style": {
                "color": { "field": "decision", "fixed": "dark-green", "mode": "field" },
                "opacity": 0.85,
                "rotation": { "fixed": 0, "max": 360, "min": -360, "mode": "mod" },
                "size": { "field": "events", "fixed": 6, "max": 24, "min": 4, "mode": "field" },
                "symbol": { "fixed": "img/icons/marker/circle.svg", "mode": "fixed" },
                "symbolAlign": { "horizontal": "center", "vertical": "center" },
                "textConfig": {
                  "fontSize": 12,
                  "offsetX": 0,
                  "offsetY": 0,
                  "textAlign": "center",
                  "textBaseline": "middle"
                }
              }
            },
            "filterData": { "id": "byRefId", "options": "A" },
            "location": { "latitude": "latitude", "longitude": "longitude", "mode": "coords" },
            "name": "Classified sources",
            "tooltip": true,
            "type": "markers"
          }
        ],
        "tooltip": { "mode": "details" },
        "view": { "allLayers": true, "id": "zero", "lat": 20, "lon": 0, "zoom": 1 }
      },
      "pluginVersion": "11.4.0",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "lureguard-pg" },
          "format": "table",
          "rawSql": "SELECT host(e.src_ip) AS src_ip, max(g.country_code) AS country_code, max(g.country_name) AS country_name, max(g.lat) AS latitude, max(g.lon) AS longitude, max(COALESCE((SELECT d.decision FROM sessions s JOIN decisions d ON d.session_id = s.id WHERE s.src_ip = e.src_ip ORDER BY abs(extract(epoch FROM (d.ts - e.ts))) LIMIT 1), CASE WHEN e.event_type IN ('auth_failed', 'cowrie_session', 'rootkit_detected', 'fim_change') THEN 'alert' WHEN e.event_type = 'auth_success' THEN 'allow' ELSE 'unclassified' END)) AS decision, count(*) AS events FROM events e JOIN ip_geolocation g ON g.ip = e.src_ip WHERE $__timeFilter(e.ts) AND e.src_ip IS NOT NULL GROUP BY e.src_ip ORDER BY events DESC",
          "refId": "A"
        }
      ],
      "title": "Classified attack traffic by country",
      "type": "geomap"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["lureguard", "siem"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "title": "LureGuard SOC Overview",
  "uid": "lureguard-soc-overview",
  "version": 3
}
