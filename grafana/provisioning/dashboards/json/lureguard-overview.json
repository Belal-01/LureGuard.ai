      "datasource": { "type": "postgres", "uid": "lureguard-pg" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 50 },
      "id": 28,
      "options": { "showHeader": true },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT h.name, h.agent_id, host(h.ip) AS ip, h.eol_os, round(100.0 * sum(CASE WHEN s.result IN ('passed', 'pass') THEN 1 ELSE 0 END) / NULLIF(sum(CASE WHEN s.result IN ('passed', 'pass', 'failed', 'fail') THEN 1 ELSE 0 END), 0), 1) AS sca_pct, (SELECT count(*) FROM user_findings u WHERE u.agent_id = h.agent_id AND u.risk_level IN ('critical', 'high', 'medium') AND u.username != '_none_') AS risky_users, (SELECT count(*) FROM cve_findings c WHERE c.agent_id = h.agent_id AND c.epss_score > 0.5 AND c.actionable = true) AS high_epss_cves, greatest((SELECT max(scanned_at) FROM cve_findings c WHERE c.agent_id = h.agent_id), (SELECT max(scanned_at) FROM sca_findings s2 WHERE s2.agent_id = h.agent_id), (SELECT max(scanned_at) FROM user_findings u2 WHERE u2.agent_id = h.agent_id)) AS last_posture_scan FROM hosts h LEFT JOIN sca_findings s ON s.agent_id = h.agent_id AND s.check_id != 'none' WHERE h.agent_id != '000' GROUP BY h.name, h.agent_id, h.ip, h.eol_os ORDER BY h.name",
          "refId": "A"
        }
      ],
      "title": "Posture summary by host",
      "type": "table"
    },
