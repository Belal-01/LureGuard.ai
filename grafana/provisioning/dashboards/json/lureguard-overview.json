      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 21 },
      "id": 17,
      "options": { "legend": { "displayMode": "list" }, "pieType": "donut" },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT CASE WHEN wazuh_rule_level >= 12 THEN '12+ critical' WHEN wazuh_rule_level >= 10 THEN '10-11 high' WHEN wazuh_rule_level >= 7 THEN '7-9 medium' WHEN wazuh_rule_level >= 3 THEN '3-6 low' ELSE '0-2 info' END AS level_band, count(*) AS value FROM events WHERE $__timeFilter(ts) AND wazuh_rule_level IS NOT NULL GROUP BY 1 ORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "Alert level distribution",
      "type": "piechart"
    },
    {
      "datasource": { "type": "postgres", "uid": "lureguard-pg" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "decision" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "allow": { "color": "green", "index": 0, "text": "allow" },
                      "alert": { "color": "red", "index": 1, "text": "alert" },
                      "redirect": { "color": "orange", "index": 2, "text": "redirect" },
                      "unclassified": { "color": "blue", "index": 3, "text": "unclassified" }
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      "gridPos": { "h": 12, "w": 16, "x": 0, "y": 29 },
      "id": 5,
      "options": {
        "basemap": {
          "name": "Layer 0",
          "type": "carto",
          "config": { "theme": "dark", "showLabels": false }
        },
        "controls": {
          "mouseWheelZoom": true,
          "showAttribution": true,
          "showDebug": false,
          "showMeasure": false,
          "showScale": false,
          "showZoom": true
        },
        "layers": [
          {
            "config": {
              "showLegend": true,
              "style": {
                "color": { "field": "decision", "fixed": "dark-green", "mode": "field" },
                "opacity": 0.85,
                "rotation": { "fixed": 0, "max": 360, "min": -360, "mode": "mod" },
                "size": { "field": "events", "fixed": 6, "max": 24, "min": 4, "mode": "field" },
                "symbol": { "fixed": "img/icons/marker/circle.svg", "mode": "fixed" },
                "symbolAlign": { "horizontal": "center", "vertical": "center" },
                "textConfig": {
                  "fontSize": 12,
                  "offsetX": 0,
                  "offsetY": 0,
                  "textAlign": "center",
                  "textBaseline": "middle"
                }
              }
            },
            "filterData": { "id": "byRefId", "options": "A" },
            "location": { "latitude": "latitude", "longitude": "longitude", "mode": "coords" },
            "name": "Classified sources",
            "tooltip": true,
            "type": "markers"
          }
        ],
        "tooltip": { "mode": "details" },
        "view": { "allLayers": true, "id": "zero", "lat": 20, "lon": 0, "zoom": 1 }
      },
      "pluginVersion": "11.4.0",
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT host(e.src_ip) AS src_ip, max(g.country_code) AS country_code, max(g.country_name) AS country_name, max(g.lat) AS latitude, max(g.lon) AS longitude, max(COALESCE((SELECT d.decision FROM sessions s JOIN decisions d ON d.session_id = s.id WHERE s.src_ip = e.src_ip ORDER BY abs(extract(epoch FROM (d.ts - e.ts))) LIMIT 1), CASE WHEN e.event_type IN ('auth_failed', 'cowrie_session', 'rootkit_detected', 'fim_change') THEN 'alert' WHEN e.event_type = 'auth_success' THEN 'allow' ELSE 'unclassified' END)) AS decision, count(*) AS events FROM events e INNER JOIN ip_geolocation g ON g.ip = e.src_ip WHERE $__timeFilter(e.ts) AND e.src_ip IS NOT NULL AND g.lat IS NOT NULL AND g.lon IS NOT NULL GROUP BY e.src_ip ORDER BY events DESC LIMIT 50",
          "refId": "A"
        }
      ],
      "title": "Geolocated attack sources",
      "type": "geomap"
    },
