          "format": "table",
          "rawSql": "SELECT count(DISTINCT agent_id) AS hosts_with_posture FROM hosts WHERE agent_id != '000' AND agent_id IN (SELECT DISTINCT agent_id FROM cve_findings UNION SELECT DISTINCT agent_id FROM sca_findings WHERE check_id != 'none' UNION SELECT DISTINCT agent_id FROM user_findings WHERE username != '_none_')",
