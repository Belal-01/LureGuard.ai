      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT coalesce(verdict, 'open') AS metric, count(*) AS value FROM investigations WHERE $__timeFilter(started_at) GROUP BY verdict",
          "refId": "A"
        }
      ],
      "title": "Investigation verdicts",
      "type": "piechart"
    },
    {
      "datasource": { "type": "postgres", "uid": "lureguard-pg" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 15 } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 5,
      "targets": [
        {
          "format": "time_series",
          "rawSql": "SELECT $__timeGroupAlias(ts, $__interval), count(*) AS value FROM agent_actions WHERE $__timeFilter(ts) GROUP BY 1 ORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "Tool calls over time",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "postgres", "uid": "lureguard-pg" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
      "id": 6,
      "options": { "showHeader": true },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT i.started_at, i.subject, i.status, i.verdict, i.severity, count(a.id) AS tool_calls FROM investigations i LEFT JOIN agent_actions a ON a.investigation_id = i.id WHERE $__timeFilter(i.started_at) GROUP BY i.id ORDER BY i.started_at DESC LIMIT 20",
          "refId": "A"
        }
      ],
      "title": "Recent investigations",
      "type": "table"
    },
    {
      "datasource": { "type": "postgres", "uid": "lureguard-pg" },
