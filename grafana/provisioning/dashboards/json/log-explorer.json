{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 2,
  "id": null,
  "links": [
    {
      "title": "SOC Overview",
      "type": "link",
      "url": "/d/lureguard-overview/lureguard-soc-overview",
      "keepTime": true
    },
    {
      "title": "Investigation Console",
      "type": "link",
      "url": "/d/lureguard-investigation/lureguard-investigation-console",
      "keepTime": true,
      "includeVars": true
    }
  ],
  "panels": [
    {
      "datasource": { "type": "postgres", "uid": "lureguard-pg" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": { "mode": "normal", "group": "A" }
          },
          "links": [
            {
              "title": "Open Investigation Console (this IP)",
              "url": "/d/lureguard-investigation/lureguard-investigation-console?var-src_ip=${__field.labels.src_ip}&${__url_time_range}"
            }
          ]
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "format": "time_series",
          "rawSql": "SELECT $__timeGroupAlias(e.ts, $__interval), host(e.src_ip) AS src_ip, count(*) AS events FROM events e WHERE $__timeFilter(e.ts) AND (NULLIF('${src_ip}', '') IS NULL OR host(e.src_ip) = NULLIF('${src_ip}', '')) AND (NULLIF('${agent_id}', '') IS NULL OR e.agent_id = NULLIF('${agent_id}', '')) AND (NULLIF('${channel}', '') IS NULL OR '${channel}' = 'All' OR e.channel = '${channel}') AND (NULLIF('${severity}', '') IS NULL OR e.wazuh_rule_level >= NULLIF('${severity}', '')::int) GROUP BY 1, 2 ORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "Event volume (click legend IP → investigation console)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "postgres", "uid": "lureguard-pg" },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "filterable": true, "inspect": true },
          "links": [
            {
              "title": "Investigate IP",
              "url": "/d/lureguard-investigation/lureguard-investigation-console?var-src_ip=${__data.fields.src_ip}&${__url_time_range}"
            }
          ]
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "wazuh_rule_level" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-background", "mode": "gradient" }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 7 },
                    { "color": "orange", "value": 10 },
                    { "color": "red", "value": 12 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 8 },
      "id": 2,
      "options": {
        "cellHeight": "sm",
        "footer": { "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "ts" }]
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT e.ts, host(e.src_ip) AS src_ip, e.channel, e.agent_id, e.agent_name, e.wazuh_rule_level, e.wazuh_rule_description, e.username, e.event_type, e.raw_ref FROM events e WHERE $__timeFilter(e.ts) AND (NULLIF('${src_ip}', '') IS NULL OR host(e.src_ip) = NULLIF('${src_ip}', '')) AND (NULLIF('${agent_id}', '') IS NULL OR e.agent_id = NULLIF('${agent_id}', '')) AND (NULLIF('${channel}', '') IS NULL OR '${channel}' = 'All' OR e.channel = '${channel}') AND (NULLIF('${severity}', '') IS NULL OR e.wazuh_rule_level >= NULLIF('${severity}', '')::int) AND (NULLIF('${search}', '') IS NULL OR e.raw_ref ILIKE '%' || NULLIF('${search}', '') || '%' OR e.wazuh_rule_description ILIKE '%' || NULLIF('${search}', '') || '%' OR e.username ILIKE '%' || NULLIF('${search}', '') || '%') ORDER BY e.ts DESC LIMIT 500",
          "refId": "A"
        }
      ],
      "title": "Event log stream (column filters + search box)",
      "type": "table"
    }
  ],
  "schemaVersion": 39,
  "tags": ["lureguard", "logs", "explorer"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "", "value": "" },
        "hide": 0,
        "label": "Source IP",
        "name": "src_ip",
        "options": [{ "selected": true, "text": "", "value": "" }],
        "query": "",
        "type": "textbox"
      },
      {
        "current": { "selected": false, "text": "All", "value": "All" },
        "datasource": { "type": "postgres", "uid": "lureguard-pg" },
        "definition": "SELECT 'All' AS channel UNION SELECT DISTINCT channel FROM events WHERE channel IS NOT NULL ORDER BY 1",
        "hide": 0,
        "includeAll": false,
        "label": "Channel",
        "name": "channel",
        "options": [],
        "query": "SELECT 'All' AS channel UNION SELECT DISTINCT channel FROM events WHERE channel IS NOT NULL ORDER BY 1",
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      },
      {
        "current": { "selected": false, "text": "", "value": "" },
        "datasource": { "type": "postgres", "uid": "lureguard-pg" },
        "definition": "SELECT DISTINCT agent_id FROM events WHERE agent_id IS NOT NULL ORDER BY 1",
        "hide": 0,
        "label": "Agent ID",
        "name": "agent_id",
        "options": [],
        "query": "SELECT DISTINCT agent_id FROM events WHERE agent_id IS NOT NULL ORDER BY 1",
        "refresh": 2,
        "type": "query"
      },
      {
        "current": { "selected": false, "text": "", "value": "" },
        "hide": 0,
        "label": "Min severity",
        "name": "severity",
        "options": [{ "selected": true, "text": "", "value": "" }],
        "query": "",
        "type": "textbox"
      },
      {
        "current": { "selected": false, "text": "", "value": "" },
        "hide": 0,
        "label": "Search in logs",
        "name": "search",
        "options": [{ "selected": true, "text": "", "value": "" }],
        "query": "",
        "type": "textbox"
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": { "refresh_intervals": ["5s", "10s", "30s", "1m", "5m"] },
  "timezone": "utc",
  "title": "LureGuard Log Explorer",
  "uid": "lureguard-log-explorer",
  "version": 1
}
