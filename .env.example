# Copy to .env and fill in (never commit .env)

# Core API auth — single source of truth for ingest token.
# Injected into both lureguard-core and wazuh-manager by docker-compose. No other file to edit.
INGEST_TOKEN=lureguard-dev-ingest-token
# INGEST_ALLOW_UNAUTHENTICATED=false  # fail closed when INGEST_TOKEN unset

# Admin API Bearer token (Core /config/* endpoints)
ADMIN_TOKEN=lureguard-dev-admin-token

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional: Telegram forum topic ID (supergroups with topics)
TELEGRAM_MESSAGE_THREAD_ID=

GRAFANA_ADMIN_PASSWORD=admin

# Wazuh Manager API (host-side MCP / doctor; default dev credentials)
WAZUH_API_URL=https://localhost:55000
WAZUH_API_USER=wazuh
WAZUH_API_PASSWORD=LureGuard-Wazuh-Dev-2026!
WAZUH_API_VERIFY_SSL=false

# Optional threat intel (MCP enrichment tools warn if unset)
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
# URLhaus uses public API by default; override only if needed
# URLHAUS_API_URL=https://urlhaus-api.abuse.ch/v1/url/

# SSH password for onboard_host MCP tool (optional; agent may prompt)
ONBOARD_SSH_PASSWORD=

# IP agents use to reach Wazuh manager (optional; auto-detected from VM route if unset)
# WAZUH_AGENT_MANAGER_IP=192.168.28.1

# IP stored on manager for new agents ('any' avoids Docker/NAT source-IP mismatch; not 0.0.0.0 — only one allowed)
# WAZUH_AGENT_REGISTER_IP=any

# AUTO_TRIAGE_LEVEL=12

# Optional — allow agent to confirm block/whitelist/restart without human (testing only; default false)
# LUREGUARD_ALLOW_AGENT_BLOCK=false
# LUREGUARD_ALLOW_AGENT_WHITELIST=false
# LUREGUARD_ALLOW_AGENT_RESTART=false

# SSH host keys: default accept-new; set true for StrictHostKeyChecking=yes
# LUREGUARD_SSH_STRICT_HOST_KEYS=false

# Optional — defaults in code if unset:
# TELEGRAM_TIMEOUT_SECONDS=3
# TELEGRAM_DEDUP_SECONDS=90
# DATABASE_URL=...  # only if you override auto DB host detection
