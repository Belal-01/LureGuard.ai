# Copy to .env (never commit .env)

# Local `make core` when Postgres runs via docker compose (host port 5433)
DATABASE_URL=postgresql+asyncpg://lureguard:lureguard@localhost:5433/lureguard

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_TIMEOUT_SECONDS=3
# Suppress repeat alerts for same IP+decision (Wazuh often fires 2 rules per attempt)
TELEGRAM_DEDUP_SECONDS=90

CONFIG_PATH=config/core.yaml
MODELS_DIR=ml/models
# Whitelist lives in Postgres (`whitelist` table). Optional one-time seed if table is empty:
# config/whitelist.json → imported on first Core startup only.
